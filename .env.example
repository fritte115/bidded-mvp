# Copy this file to .env and fill in local values.
# Never commit .env or paste secrets into chat.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=public-procurements

# Optional. Keep EMBEDDING_MODE=mock unless live embeddings are intentionally configured.
EMBEDDING_MODE=mock
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
