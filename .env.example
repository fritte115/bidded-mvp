# Copy to .env and fill in local values. Never commit .env or paste secrets into chat.
# Swarm: auto (Anthropic when ANTHROPIC_API_KEY is set, otherwise deterministic),
# evidence_locked (force deterministic), or anthropic (require Claude API).
# Loaded via BiddedSettings from this file (no need to export in the shell).
# BIDDED_SWARM_BACKEND=auto
# Anthropic model routing: mixed uses Haiku for bounded/low-risk roles and
# Sonnet for high-stakes roles; single forces legacy one-model behavior.
# BIDDED_ANTHROPIC_MODEL_ROUTING=mixed
# Model id for legacy/single routing and default reasoning fallback.
# BIDDED_ANTHROPIC_MODEL=claude-sonnet-4-6
# BIDDED_ANTHROPIC_FAST_MODEL=claude-haiku-4-5
# BIDDED_ANTHROPIC_REASONING_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=public-procurements

# Optional. Keep EMBEDDING_MODE=mock unless live embeddings are intentionally configured.
EMBEDDING_MODE=mock
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
