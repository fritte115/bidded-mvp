# Copy to .env and fill in local values. Never commit .env or paste secrets into chat.
# Swarm: evidence_locked (default, deterministic) or anthropic (Claude API).
# Loaded via BiddedSettings from this file (no need to export in the shell).
# BIDDED_SWARM_BACKEND=anthropic
# Model id for the swarm only — use BIDDED_ANTHROPIC_MODEL (not ANTHROPIC_MODEL).
# BIDDED_ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=public-procurements

# Optional. Keep mock unless a live embedding provider is intentionally configured.
EMBEDDING_PROVIDER=mock
